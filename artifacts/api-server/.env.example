# ============================================================
# SIGNALMASTER PRO v7 — variáveis de ambiente necessárias
# ============================================================
# Este arquivo é só documentação. NÃO coloque valores reais aqui.
# No Replit: configure tudo em Secrets (aba cadeado) ou env vars.
# Em outros ambientes: copie para .env e preencha os valores.
# ============================================================

# ── Banco de dados ──────────────────────────────────────────
# Gerenciado automaticamente pelo Replit PostgreSQL.
# Em outros ambientes: connection string do PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/signalmaster

# ── Autenticação JWT ────────────────────────────────────────
# Access token (expira em 15min). String aleatória longa.
# Gerar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque-por-string-aleatoria-longa-minimo-64-chars

# Refresh token (expira em 30d). DEVE ser diferente do SESSION_SECRET.
# Gerar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
REFRESH_SECRET=troque-por-outra-string-aleatoria-diferente-da-acima

# ── E-mail (Resend) ─────────────────────────────────────────
# Chave da API Resend para envio de e-mails e relatórios diários.
# Obter em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Pagamentos (Stripe) ─────────────────────────────────────
# Chave secreta do Stripe (nunca a chave pública aqui).
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave pública do Stripe (essa sim vai ao frontend).
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret do Stripe (OBRIGATÓRIO para processar assinaturas com segurança).
# Obter em: https://dashboard.stripe.com/webhooks após criar o webhook.
# SEM esta chave o endpoint de webhook é bloqueado automaticamente.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs dos planos (Stripe Dashboard → Products).
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Servidor ────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── CORS / Domínio ──────────────────────────────────────────
# Em produção, defina o domínio do frontend para restringir CORS.
# Exemplo: meuapp.com (sem https://)
PRODUCTION_DOMAIN=

# ── Replit (gerenciados automaticamente, não editar) ────────
# REPLIT_DEV_DOMAIN — domínio de preview, injetado pelo Replit.
# REPLIT_DEPLOYMENT — definido em produção pelo Replit.
